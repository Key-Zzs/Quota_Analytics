<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/quota_widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/quota_widget_background"
    android:orientation="vertical"
    android:padding="14dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/widget_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:ellipsize="end"
            android:maxLines="1"
            android:text="@string/quota_widget_title"
            android:textColor="@color/quota_widget_on_background"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/stale_badge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/quota_widget_badge_background"
            android:maxLines="1"
            android:textColor="@color/quota_widget_badge_text"
            android:textSize="10sp"
            android:textStyle="bold"
            android:visibility="gone" />

        <TextView
            android:id="@+id/quota_widget_refresh"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:layout_marginLeft="8dp"
            android:background="@drawable/quota_widget_badge_background"
            android:gravity="center"
            android:maxLines="1"
            android:minWidth="64dp"
            android:paddingLeft="10dp"
            android:paddingRight="10dp"
            android:text="@string/quota_widget_refresh"
            android:textColor="@color/quota_widget_badge_text"
            android:textSize="10sp"
            android:textStyle="bold" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="8dp"
        android:layout_weight="1"
        android:baselineAligned="false"
        android:orientation="horizontal">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center_vertical"
            android:orientation="vertical">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/quota_widget_five_hour_label"
                android:textColor="@color/quota_widget_secondary_text"
                android:textSize="11sp" />

            <TextView
                android:id="@+id/five_hour_value"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:maxLines="1"
                android:text="@string/quota_widget_no_data_short"
                android:textColor="@color/quota_widget_accent"
                android:textSize="26sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/five_hour_reset"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:maxLines="1"
                android:text="@string/quota_widget_reset_unknown"
                android:textColor="@color/quota_widget_secondary_text"
                android:textSize="11sp" />
        </LinearLayout>

        <TextView
            android:layout_width="1dp"
            android:layout_height="match_parent"
            android:layout_marginLeft="12dp"
            android:layout_marginRight="12dp"
            android:background="@color/quota_widget_divider" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center_vertical"
            android:orientation="vertical">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/quota_widget_weekly_label"
                android:textColor="@color/quota_widget_secondary_text"
                android:textSize="11sp" />

            <TextView
                android:id="@+id/weekly_value"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:maxLines="1"
                android:text="@string/quota_widget_no_data_short"
                android:textColor="@color/quota_widget_accent"
                android:textSize="26sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/weekly_reset"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:maxLines="1"
                android:text="@string/quota_widget_reset_unknown"
                android:textColor="@color/quota_widget_secondary_text"
                android:textSize="11sp" />
        </LinearLayout>
    </LinearLayout>

    <TextView
        android:id="@+id/credits_value"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:ellipsize="end"
        android:maxLines="1"
        android:textColor="@color/quota_widget_on_background"
        android:textSize="11sp"
        android:textStyle="bold"
        android:visibility="gone" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/source_confidence"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:ellipsize="end"
            android:maxLines="1"
            android:text="@string/quota_widget_summary_only"
            android:textColor="@color/quota_widget_secondary_text"
            android:textSize="11sp" />

        <TextView
            android:id="@+id/last_updated"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:maxLines="1"
            android:text="@string/quota_widget_updated_none"
            android:textColor="@color/quota_widget_secondary_text"
            android:textSize="11sp" />
    </LinearLayout>
</LinearLayout>
